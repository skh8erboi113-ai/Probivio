# =============================================================================
# ENVIRONMENT
# =============================================================================
NODE_ENV=development

# =============================================================================
# STREAMLINE API (apps/streamline)
# =============================================================================
PORT=8080

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANB...\n-----END PRIVATE KEY-----\n"

# Google Gemini AI (Optional but recommended)
GEMINI_API_KEY=your-gemini-api-key

# Twilio (Optional)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# SendGrid (Optional)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=alerts@yourdomain.com

# Telegram (Optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Discord (Optional — for ops alerts)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# Skip Trace (Optional — 3-tier fallback)
SKIP_TRACE_API_KEY=your-skip-trace-key

# Redis (Optional — enables distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Sentry (Optional)
SENTRY_DSN=https://xxxxx@sentry.io/yyyyy

# Security
JWT_SECRET=change-me-min-32-chars-in-production-please-1234567890
SESSION_SECRET=change-me-min-32-chars-in-production-please-0987654321

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# WEB APP (apps/web) — Vite variables must be prefixed with VITE_
# =============================================================================
VITE_API_URL=http://localhost:8080
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
