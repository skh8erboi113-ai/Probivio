{
  "name": "@probivio/types",
  "version": "2.1.0",
  "private": true,
  "description": "Shared TypeScript domain models for the Probivio monorepo",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./lead": {
      "types": "./dist/lead.d.ts",
      "import": "./dist/lead.js"
    },
    "./buyer": {
      "types": "./dist/buyer.d.ts",
      "import": "./dist/buyer.js"
    },
    "./probate": {
      "types": "./dist/probate.d.ts",
      "import": "./dist/probate.js"
    },
    "./automation": {
      "types": "./dist/automation.d.ts",
      "import": "./dist/automation.js"
    },
    "./interaction": {
      "types": "./dist/interaction.d.ts",
      "import": "./dist/interaction.js"
    },
    "./scoring": {
      "types": "./dist/scoring.d.ts",
      "import": "./dist/scoring.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    }
  },
  "scripts": {
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^3.0.1",
    "typescript": "^5.9.3",
    "eslint-config-prettier": "^10.1.8"
  }
}
