{
  "name": "@probivio/streamline",
  "version": "2.1.0",
  "private": true,
  "description": "Streamline Probate Engine \u2014 Express API for real estate wholesaling automation",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:load:baseline": "k6 run tests/load/k6-baseline.js",
    "test:load:scoring": "k6 run tests/load/k6-scoring-stress.js",
    "clean": "rm -rf dist coverage .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/tasks": "^6.2.3",
    "@google/generative-ai": "^0.24.1",
    "@probivio/db": "workspace:*",
    "@probivio/logger": "workspace:*",
    "@probivio/types": "workspace:*",
    "@probivio/validators": "workspace:*",
    "@sendgrid/mail": "^8.1.6",
    "@sentry/node": "^10.67.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.6.0",
    "firebase-admin": "^14.2.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "onnxruntime-node": "^1.17.0",
    "pdf-parse": "^1.1.1",
    "rate-limit-redis": "^5.0.0",
    "ws": "^8.21.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^20.19.9",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-security": "^3.0.1",
    "supertest": "^7.2.2",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "eslint-config-prettier": "^10.1.8"
  }
}
