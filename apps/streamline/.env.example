# =============================================================================
# Streamline API — Environment Variables
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ─── Firebase Admin SDK (REQUIRED) ────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate Key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQI...your-key...\n-----END PRIVATE KEY-----\n"

# ─── Security (REQUIRED) ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-64-char-hex-string-minimum-32-chars
SESSION_SECRET=replace-with-different-64-char-hex-string

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Google Gemini AI (strongly recommended) ──────────────────────────────────
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── Twilio (for SMS automations) ────────────────────────────────────────────
# Get from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+15551234567

# ─── SendGrid (for email automations) ────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx.xxxx
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ─── Telegram (for operator alerts) ──────────────────────────────────────────
# Get from: @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...

# ─── Discord (for ops alerts) ─────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/yyy

# ─── Skip Trace (3-tier fallback property lookup) ─────────────────────────────
SKIP_TRACE_API_KEY=your-skip-trace-api-key

# ─── Redis (enables distributed rate limiting) ────────────────────────────────
# Local dev: redis://localhost:6379
# Cloud Memorystore: redis://10.x.x.x:6379
REDIS_URL=redis://localhost:6379

# ─── Sentry (production error tracking) ──────────────────────────────────────
# Get from: https://sentry.io
SENTRY_DSN=https://xxxxx@sentry.io/yyyyy

# ─── Feature flags ────────────────────────────────────────────────────────────
ENABLE_ML_RETRAINING=true
ENABLE_AUTOMATION_ENGINE=true
ENABLE_PROBATE_SCANNER=true
