{
  "name": "@listinglogic/streamline",
  "version": "2.1.0",
  "private": true,
  "description": "Streamline Probate Engine — Express API for real estate wholesaling automation",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:load:baseline": "k6 run tests/load/k6-baseline.js",
    "test:load:scoring": "k6 run tests/load/k6-scoring-stress.js",
    "clean": "rm -rf dist coverage .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.7.0",
    "@google-cloud/tasks": "^6.2.3",
    "@google/generative-ai": "^0.24.1",
    "@listinglogic/db": "workspace:*",
    "@listinglogic/logger": "workspace:*",
    "@listinglogic/types": "workspace:*",
    "@listinglogic/validators": "workspace:*",
    "@sendgrid/mail": "^8.1.1",
    "@sentry/node": "^10.63.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "firebase-admin": "^14.1.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "onnxruntime-node": "^1.17.0",
    "pdf-parse": "^1.1.1",
    "rate-limit-redis": "^4.2.0",
    "twilio": "^4.22.0",
    "ws": "^8.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
