{
  "name": "probivio-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Probivio / Streamline Probate Engine — pnpm + Turborepo monorepo root",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@probivio/streamline",
    "dev:web": "turbo run dev --filter=@probivio/web",
    "build": "turbo run build",
    "start": "node apps/streamline/dist/index.js",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:coverage": "turbo run test:coverage",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.9.5",
    "turbo": "^2.10.5"
  },
  "pnpm": {
    "overrides": {
      "uuid@<11.1.1": ">=11.1.1"
    }
  }
}
